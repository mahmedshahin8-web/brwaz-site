{
  "entities": {
    "Metrics": {
      "title": "System Metrics",
      "description": "System usage metrics",
      "type": "object",
      "properties": {
        "tokensProcessed": { "type": "number" },
        "lastGhostSync": { "type": "string", "format": "date-time" }
      }
    },
    "Dossier": {
      "title": "Dossier",
      "description": "Generated content dossiers",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "title": { "type": "string" },
        "content": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      }
    },
    "PropRoomItem": {
      "title": "Prop Room Item",
      "description": "Saved assets and props",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "type": { "type": "string" },
        "name": { "type": "string" },
        "description": { "type": "string" },
        "metadata": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      }
    },
    "RenderJob": {
      "title": "Render Job",
      "description": "Render engine tracking",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "projectId": { "type": "string" },
        "status": { "type": "string" },
        "progress": { "type": "number" },
        "logs": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      }
    }
  },
  "firestore": {
    "system/metrics": {
      "schema": { "$ref": "#/entities/Metrics" },
      "description": "Global usage metrics"
    },
    "dossiers/{dossierId}": {
      "schema": { "$ref": "#/entities/Dossier" },
      "description": "User generated dossiers"
    },
    "prop_room/{propId}": {
      "schema": { "$ref": "#/entities/PropRoomItem" },
      "description": "Shared project props"
    },
    "render_jobs/{jobId}": {
      "schema": { "$ref": "#/entities/RenderJob" },
      "description": "Rendering status tracker"
    }
  }
}
